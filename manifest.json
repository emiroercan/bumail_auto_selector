{
  "manifest_version": 3,
  "name": "Bumail Auto Select",
  "version": "1.1.1",
  "description": "Bumail giriş sayfasında Student, Yarızamanlı ya da Emekli seçeneklerinden bir tanesini otomatik olarak seçmenizi sağlar",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Bumail Auto Select",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://bumail.bogazici.edu.tr/*",
        "*://mail.bogazici.edu.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
